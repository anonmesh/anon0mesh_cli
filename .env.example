# ── Solana ────────────────────────────────────────────────────────────────────
SOLANA_NETWORK=devnet
# Leave blank to use default public endpoint, or set a Helius/QuickNode URL:
# SOLANA_RPC_URL=https://devnet.helius-rpc.com/?api-key=YOUR_KEY

# ── Arcium MPC ────────────────────────────────────────────────────────────────
# Set to 1 to enable confidential transactions via Arcium
ARCIUM_ENABLED=0

# Your Solana wallet keypair (payer for Arcium computation fees)
ARCIUM_PAYER_KEYPAIR=~/.config/solana/id.json

# Solana RPC endpoint for Arcium transactions
ARCIUM_RPC_URL=https://api.devnet.solana.com

# Your deployed MXE program ID — get this from: arcium deploy from your Anchor && Arcis programs directory
ARCIUM_MXE_PROGRAM_ID=

# MXE x25519 public key — get this from: node rescue_shim.mjs mxe_pubkey <PROGRAM_ID>
ARCIUM_MXE_PUBKEY_HEX=

# Arcium cluster offset: 456 = devnet, 2026 = mainnet-alpha
ARCIUM_CLUSTER_OFFSET=456

# ── Beacon announce ───────────────────────────────────────────────────────────
# Seconds between re-announces after the 2-minute burst window
ANNOUNCE_INTERVAL=300